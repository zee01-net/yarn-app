// ==================== TABLE RENDER ====================
function inwardRefreshTables() {
    const master = inwardCache;
    const grouped = getGroupedList(master);

    // Table A
    const tbodyA = document.querySelector('#in_tableA tbody');
    const tfootA = document.querySelector('#in_tableA tfoot');
    const thsA = in_headersA.map((h, i) =>
        `<th onclick="sortTable('inA',${i})">${h}<span class="sort-icon"></span></th>`
    ).join('');
    document.querySelector('#in_tableA thead').innerHTML =
        `<tr><th class="cb-col"><input type="checkbox" id="inA_checkAll" onchange="toggleAllCheckboxes('inA',this)"></th>${thsA}<th>ACTION</th></tr>`;
    applySortIcons('inA', in_headersA.length + 1);

    let totalBagsA = 0, totalPacksA = 0;
    tbodyA.innerHTML = '';
    master.forEach((item, i) => {
        const row = tbodyA.insertRow();
        row.dataset.idx = i;
        row.insertCell().innerHTML = `<div class="cb-col"><input type="checkbox" class="inA-cb" onchange="onCheckboxChange('inA')" data-idx="${i}"></div>`;
        in_keys.forEach(k => row.insertCell().innerText = item[k] || '-');
        row.insertCell().innerHTML =
            `<button class="icon-btn edit-btn" onclick="inwardLoadForEdit(${i})">✎</button>` +
            `<button class="icon-btn copy-btn" onclick="inwardDuplicateRow(${i})" title="Duplicate">⧉</button>` +
            `<button class="icon-btn del-btn" onclick="inwardDeleteRow(${i})">✕</button>`;
        totalBagsA += parseFloat(item.netBag) || 0;
        totalPacksA += parseFloat(item.netPack) || 0;
    });
    tfootA.innerHTML = `<tr><td></td><td colspan="10" style="text-align:right">GRAND TOTAL:</td><td>${totalBagsA}</td><td>${totalPacksA}</td><td colspan="4"></td></tr>`;

    // Table B
    const outMap = new Map();
    outwardCache.forEach(item => {
        const key = `${item.count}|${item.brand}|${item.lotNo}|${item.peparCon}|${item.conPrBag}`.toUpperCase();
        const b = parseFloat(item.netBag) || 0, p = parseFloat(item.netPack) || 0;
        if (!outMap.has(key)) outMap.set(key, { outBag: b, outPack: p });
        else { outMap.get(key).outBag += b; outMap.get(key).outPack += p; }
    });

    const tbodyB = document.querySelector('#in_tableB tbody');
    const tfootB = document.querySelector('#in_tableB tfoot');
    document.querySelector('#in_tableB thead').innerHTML = `<tr>${in_headersB.map(h => `<th>${h}</th>`).join('')}</tr>`;

    let tBagIn = 0, tPackIn = 0, tBagOut = 0, tPackOut = 0;
    tbodyB.innerHTML = '';
    grouped.forEach((item, i) => {
        const key = `${item.count}|${item.brand}|${item.lotNo}|${item.peparCon}|${item.conPrBag}`.toUpperCase();
        const out = outMap.get(key) || { outBag: 0, outPack: 0 };
        const remBag = item.sumBag - out.outBag, remPack = item.sumPack - out.outPack;
        const row = tbodyB.insertRow();
        row.insertCell().innerText = i + 1;
        row.insertCell().innerText = item.count || '';
        row.insertCell().innerText = item.brand || '';
        row.insertCell().innerText = item.lotNo || '';
        row.insertCell().innerText = item.peparCon || '';
        row.insertCell().innerText = item.conPrBag || '';
        row.insertCell().innerHTML = `<span style="color:#059669;font-weight:bold">${item.sumBag}</span>`;
        row.insertCell().innerHTML = `<span style="color:#059669;font-weight:bold">${item.sumPack}</span>`;
        row.insertCell().innerHTML = `<span style="color:#e11d48;font-weight:bold">${out.outBag}</span>`;
        row.insertCell().innerHTML = `<span style="color:#e11d48;font-weight:bold">${out.outPack}</span>`;
        row.insertCell().innerHTML = `<span class="sum-only" style="color:${remBag < 0 ? '#e11d48' : '#4f46e5'}">${remBag}</span>`;
        row.insertCell().innerHTML = `<span class="sum-only" style="color:${remPack < 0 ? '#e11d48' : '#4f46e5'}">${remPack}</span>`;
        row.insertCell().innerHTML = `${item.party || ''} ${item.rowCount > 1 ? `<span class="freq-badge">${item.rowCount}</span>` : ''}`;
        tBagIn += item.sumBag; tPackIn += item.sumPack; tBagOut += out.outBag; tPackOut += out.outPack;
    });
    const remTB = tBagIn - tBagOut, remTP = tPackIn - tPackOut;
    tfootB.innerHTML = `<tr><td colspan="6" style="text-align:right;font-weight:bold">TOTALS:</td>
        <td style="color:#059669">${tBagIn}</td><td style="color:#059669">${tPackIn}</td>
        <td style="color:#e11d48">${tBagOut}</td><td style="color:#e11d48">${tPackOut}</td>
        <td style="color:#4f46e5;font-weight:bold">${remTB}</td>
        <td style="color:#4f46e5;font-weight:bold">${remTP}</td><td></td></tr>`;
}

function outwardRefreshTables() {
    const master = outwardCache;
    const tbodyA = document.querySelector('#out_tableA tbody');
    const tfootA = document.querySelector('#out_tableA tfoot');
    const thsA = out_headersA.map((h, i) =>
        `<th onclick="sortTable('outA',${i})">${h}<span class="sort-icon"></span></th>`
    ).join('');
    document.querySelector('#out_tableA thead').innerHTML =
        `<tr><th class="cb-col"><input type="checkbox" id="outA_checkAll" onchange="toggleAllCheckboxes('outA',this)"></th>${thsA}<th>ACTION</th></tr>`;
    applySortIcons('outA', out_headersA.length + 1);

    let totalBagsA = 0, totalPacksA = 0;
    tbodyA.innerHTML = '';
    master.forEach((item, i) => {
        const row = tbodyA.insertRow();
        row.dataset.idx = i;
        row.insertCell().innerHTML = `<div class="cb-col"><input type="checkbox" class="outA-cb" onchange="onCheckboxChange('outA')" data-idx="${i}"></div>`;
        out_keys.forEach(k => row.insertCell().innerText = item[k] || '-');
        row.insertCell().innerHTML =
            `<button class="icon-btn edit-btn" onclick="outwardLoadForEdit(${i})">✎</button>` +
            `<button class="icon-btn copy-btn" onclick="outwardDuplicateRow(${i})" title="Duplicate">⧉</button>` +
            `<button class="icon-btn del-btn" onclick="outwardDeleteRow(${i})">✕</button>`;
        totalBagsA += parseFloat(item.netBag) || 0;
        totalPacksA += parseFloat(item.netPack) || 0;
    });
    tfootA.innerHTML = `<tr><td></td><td colspan="12" style="text-align:right">GRAND TOTAL:</td><td>${totalBagsA}</td><td>${totalPacksA}</td><td colspan="3"></td></tr>`;
}

function getGroupedList(masterData) {
    const map = new Map();
    masterData.forEach(item => {
        const key = `${item.count}|${item.brand}|${item.lotNo}|${item.peparCon}|${item.conPrBag}|${item.party}`.toUpperCase();
        const b = parseFloat(item.netBag) || 0, p = parseFloat(item.netPack) || 0;
        if (!map.has(key)) map.set(key, { ...item, sumBag: b, sumPack: p, rowCount: 1 });
        else { const ex = map.get(key); ex.sumBag += b; ex.sumPack += p; ex.rowCount += 1; }
    });
    return Array.from(map.values());
}

// ==================== EXPORT ====================
function inwardExport(type, format) {
    if (!inwardCache.length) return alert("No data to export");
    const data = type === 'A' ? inwardCache : getGroupedList(inwardCache);
    const ws = XLSX.utils.json_to_sheet(data);
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, "InwardData");
    if (format === 'xlsx') XLSX.writeFile(wb, `Yarn_Inward_${type}.xlsx`);
    else {
        const { jsPDF } = window.jspdf;
        const doc = new jsPDF('l');
        doc.autoTable({ html: type === 'A' ? '#in_tableA' : '#in_tableB' });
        doc.save(`Yarn_Inward_${type}.pdf`);
    }
}

function outwardExport(format) {
    if (!outwardCache.length) return alert("No data to export");
    const ws = XLSX.utils.json_to_sheet(outwardCache);
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, "OutwardData");
    if (format === 'xlsx') XLSX.writeFile(wb, `Yarn_Outward_Master.xlsx`);
    else {
        const { jsPDF } = window.jspdf;
        const doc = new jsPDF('l');
        doc.autoTable({ html: '#out_tableA' });
        doc.save(`Yarn_Outward_Master.pdf`);
    }
}

// ==================== SORT ====================
function sortTable(prefix, colIdx) {
    const ss = sortState[prefix];
    if (ss.col === colIdx) ss.dir *= -1;
    else { ss.col = colIdx; ss.dir = 1; }
    const tableId = prefix === 'inA' ? 'in_tableA' : 'out_tableA';
    const tbody = document.querySelector(`#${tableId} tbody`);
    const rows = Array.from(tbody.querySelectorAll('tr'));
    rows.sort((a, b) => {
        const ta = a.cells[colIdx + 1] ? a.cells[colIdx + 1].innerText.trim() : '';
        const tb = b.cells[colIdx + 1] ? b.cells[colIdx + 1].innerText.trim() : '';
        const na = parseFloat(ta), nb = parseFloat(tb);
        if (!isNaN(na) && !isNaN(nb)) return (na - nb) * ss.dir;
        return ta.localeCompare(tb) * ss.dir;
    });
    rows.forEach(r => tbody.appendChild(r));
    applySortIcons(prefix, prefix === 'inA' ? in_headersA.length + 1 : out_headersA.length + 1);
    reapplySearches();
}

function applySortIcons(prefix, totalCols) {
    const ss = sortState[prefix];
    const tableId = prefix === 'inA' ? 'in_tableA' : 'out_tableA';
    const ths = document.querySelectorAll(`#${tableId} thead th`);
    ths.forEach((th, i) => {
        const dataColIdx = i - 1;
        th.classList.remove('sort-asc', 'sort-desc');
        if (dataColIdx === ss.col) th.classList.add(ss.dir === 1 ? 'sort-asc' : 'sort-desc');
    });
}

// ==================== FILTER ====================
const searchConfig = {
    inA:  { tableId: 'in_tableA',  countCol: 3, brandCol: 4, dateCol: 1 },
    inB:  { tableId: 'in_tableB',  countCol: 1, brandCol: 2, dateCol: -1 },
    outA: { tableId: 'out_tableA', countCol: 3, brandCol: 4, dateCol: 1 },
};

function filterTable(prefix) {
    const cfg = searchConfig[prefix];
    const countQ = (document.getElementById(`${prefix}_countInput`)?.value || '').trim().toLowerCase();
    const brandQ = (document.getElementById(`${prefix}_brandInput`)?.value || '').trim().toLowerCase();
    const dateFrom = document.getElementById(`${prefix}_dateFrom`)?.value || '';
    const dateTo   = document.getElementById(`${prefix}_dateTo`)?.value || '';

    const rows = document.querySelectorAll(`#${cfg.tableId} tbody tr`);
    let visible = 0;
    rows.forEach(row => {
        const countText = row.cells[cfg.countCol]?.innerText.toLowerCase() || '';
        const brandText = row.cells[cfg.brandCol]?.innerText.toLowerCase() || '';
        const dateText  = cfg.dateCol >= 0 ? (row.cells[cfg.dateCol]?.innerText || '') : '';
        const countMatch = !countQ || countText.includes(countQ);
        const brandMatch = !brandQ || brandText.includes(brandQ);
        let dateMatch = true;
        if (dateFrom && dateText) dateMatch = dateMatch && dateText >= dateFrom;
        if (dateTo   && dateText) dateMatch = dateMatch && dateText <= dateTo;
        const show = countMatch && brandMatch && dateMatch;
        row.style.display = show ? '' : 'none';
        if (show) visible++;
    });
    const countEl = document.getElementById(`${prefix}_rowCount`);
    if (countEl) {
        const total = rows.length;
        countEl.textContent = (countQ || brandQ || dateFrom || dateTo) ? `${visible}/${total} rows` : '';
    }
}

function clearSearch(prefix) {
    ['countInput','brandInput','dateFrom','dateTo'].forEach(id => {
        const el = document.getElementById(`${prefix}_${id}`);
        if (el) el.value = '';
    });
    const cfg = searchConfig[prefix];
    document.querySelectorAll(`#${cfg.tableId} tbody tr`).forEach(r => r.style.display = '');
    const countEl = document.getElementById(`${prefix}_rowCount`);
    if (countEl) countEl.textContent = '';
}

function reapplySearches() {
    ['inA','inB','outA'].forEach(p => {
        const cq = document.getElementById(`${p}_countInput`)?.value.trim();
        const bq = document.getElementById(`${p}_brandInput`)?.value.trim();
        const df = document.getElementById(`${p}_dateFrom`)?.value;
        const dt = document.getElementById(`${p}_dateTo`)?.value;
        if (cq || bq || df || dt) filterTable(p);
    });
}

// ==================== BULK CHECKBOX ====================
function onCheckboxChange(prefix) {
    const cbs = document.querySelectorAll(`.${prefix}-cb:checked`);
    const bar = document.getElementById(`${prefix}_bulkBar`);
    const countEl = document.getElementById(`${prefix}_bulkCount`);
    if (cbs.length > 0) { bar.classList.add('visible'); countEl.textContent = `${cbs.length} selected`; }
    else { bar.classList.remove('visible'); }
}

function toggleAllCheckboxes(prefix, masterCb) {
    document.querySelectorAll(`.${prefix}-cb`).forEach(cb => {
        if (cb.closest('tr').style.display !== 'none') cb.checked = masterCb.checked;
    });
    onCheckboxChange(prefix);
}

function cancelBulk(prefix) {
    document.querySelectorAll(`.${prefix}-cb`).forEach(cb => cb.checked = false);
    const allCb = document.getElementById(`${prefix}_checkAll`);
    if (allCb) allCb.checked = false;
    document.getElementById(`${prefix}_bulkBar`).classList.remove('visible');
}

// ==================== DASHBOARD ====================
function updateDashboards() {
    const tBagIn   = inwardCache.reduce((s, i) => s + (parseFloat(i.netBag) || 0), 0);
    const tPackIn  = inwardCache.reduce((s, i) => s + (parseFloat(i.netPack) || 0), 0);
    const tBagOut  = outwardCache.reduce((s, i) => s + (parseFloat(i.netBag) || 0), 0);
    const tPackOut = outwardCache.reduce((s, i) => s + (parseFloat(i.netPack) || 0), 0);
    const uniqueSKUs = new Set(inwardCache.map(i => `${i.count}|${i.brand}|${i.lotNo}`)).size;
    const uniqueParties = new Set(outwardCache.map(i => i.party).filter(Boolean)).size;

    document.getElementById('dash_in_bags').textContent   = tBagIn;
    document.getElementById('dash_in_packs').textContent  = tPackIn;
    document.getElementById('dash_out_bags').textContent  = tBagOut;
    document.getElementById('dash_out_packs').textContent = tPackOut;
    document.getElementById('dash_rem_bags').textContent  = tBagIn - tBagOut;
    document.getElementById('dash_rem_packs').textContent = tPackIn - tPackOut;
    document.getElementById('dash_skus').textContent      = uniqueSKUs;
    document.getElementById('dash_entries').textContent   = inwardCache.length;
    document.getElementById('dash_out2_bags').textContent    = tBagOut;
    document.getElementById('dash_out2_packs').textContent   = tPackOut;
    document.getElementById('dash_out2_parties').textContent = uniqueParties;
    document.getElementById('dash_out2_entries').textContent = outwardCache.length;
}

// ==================== BACKUP ====================
const LAST_BACKUP_KEY = 'yarn_last_backup_date';

function checkBackupReminder() {
    const last = localStorage.getItem(LAST_BACKUP_KEY);
    const dismissed = localStorage.getItem('yarn_backup_dismissed_today');
    if (dismissed === new Date().toDateString()) return;
    if (!last) {
        const total = inwardCache.length + outwardCache.length;
        if (total > 0) document.getElementById('backupBar').classList.add('visible');
        return;
    }
    const daysSince = (Date.now() - new Date(last).getTime()) / 86400000;
    if (daysSince >= 7) document.getElementById('backupBar').classList.add('visible');
}

function doBackupExport() {
    const wb = XLSX.utils.book_new();
    if (inwardCache.length) XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(inwardCache), "Inward");
    if (outwardCache.length) XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(outwardCache), "Outward");
    XLSX.writeFile(wb, `Yarn_Backup_${new Date().toISOString().slice(0,10)}.xlsx`);
    localStorage.setItem(LAST_BACKUP_KEY, new Date().toISOString());
    document.getElementById('backupBar').classList.remove('visible');
    showToast("✅ Backup saved successfully!");
}

function dismissBackup() {
    localStorage.setItem('yarn_backup_dismissed_today', new Date().toDateString());
    document.getElementById('backupBar').classList.remove('visible');
}

// ==================== TOAST ====================
function showToast(msg, withUndo = false) {
    clearTimeout(toastTimer);
    const toast = document.getElementById('toast');
    const undoBtn = document.getElementById('toast-undo-btn');
    document.getElementById('toast-msg').textContent = msg;
    undoBtn.className = withUndo ? 'visible' : '';
    toast.classList.remove('hiding');
    toast.classList.add('show');
    toastTimer = setTimeout(hideToast, withUndo ? 5000 : 2500);
}

function hideToast() {
    const toast = document.getElementById('toast');
    toast.classList.add('hiding');
    toast.classList.remove('show');
    setTimeout(() => { toast.classList.remove('hiding'); toast.style.visibility = 'hidden'; }, 400);
    setTimeout(() => { toast.style.visibility = ''; }, 500);
}

// ==================== TABS ====================
function switchTab(n) {
    document.querySelectorAll('.tab-button').forEach((btn, i) => btn.classList.toggle('active', i === n));
    document.querySelectorAll('.tab-content').forEach((c, i) => c.classList.toggle('active', i === n));
}

