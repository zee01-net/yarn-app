    showLoading('Deleting…');
    const { error } = await db.from('outward').delete().eq('id', item.id);
    hideLoading();
    if (error) return alert('Error deleting: ' + error.message);
    undoStack = { type: 'out', data: item, index };
    outwardCache.splice(index, 1);
    refreshAll();
    showToast("Entry Deleted", true);
}

// ==================== IMPORT (batch insert) ====================
async function inwardHandleImport(e) {
    const reader = new FileReader();
    reader.onload = async ev => {
        try {
            const wb = XLSX.read(ev.target.result, { type: 'binary' });
            const imported = XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]]);
            // strip any id fields that might conflict
            const clean = imported.map(r => { const c = {...r}; delete c.id; return c; });
            showLoading('Importing…');
            const { data, error } = await db.from('inward').insert(clean).select();
            hideLoading();
            if (error) return alert('Import error: ' + error.message);
            inwardCache = inwardCache.concat(data);
            refreshAll();
            showToast("Inward Data Imported!");
        } catch(err) { alert("Error importing file: " + err.message); }
    };
    reader.readAsBinaryString(e.target.files[0]);
    e.target.value = '';
}

async function outwardHandleImport(e) {
    const reader = new FileReader();
    reader.onload = async ev => {
        try {
            const wb = XLSX.read(ev.target.result, { type: 'binary' });
            const imported = XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]]);
            const clean = imported.map(r => { const c = {...r}; delete c.id; return c; });
            showLoading('Importing…');
            const { data, error } = await db.from('outward').insert(clean).select();
            hideLoading();
            if (error) return alert('Import error: ' + error.message);
            outwardCache = outwardCache.concat(data);
            refreshAll();
            showToast("Outward Data Imported!");
        } catch(err) { alert("Error importing file: " + err.message); }
    };
    reader.readAsBinaryString(e.target.files[0]);
    e.target.value = '';
}

// ==================== BULK DELETE ====================
function bulkDelete(type) {
    const prefix = type === 'in' ? 'inA' : 'outA';
    const selected = [...document.querySelectorAll(`.${prefix}-cb:checked`)];
    const indices = selected.map(cb => parseInt(cb.dataset.idx));
    if (!indices.length) return;
    if (!confirm(`Delete ${indices.length} selected record(s) permanently?`)) return;
    if (type === 'in') {
        const ids = indices.map(i => inwardCache[i].id);
        inwardBulkDelete(ids, indices);
    } else {
        const ids = indices.map(i => outwardCache[i].id);
        outwardBulkDelete(ids, indices);
    }
}

// ==================== HELPERS ====================
function buildEntry(prefix, keys) {
    const entry = {};
    keys.forEach(k => {
        const el = document.getElementById(`${prefix}${k}`);
        entry[k] = el ? el.value : '';
    });
    return entry;
}

// ==================== AUTO CALC ====================
function inwardSetupAutoCalc() {
    document.getElementById('in_netWt').addEventListener('input', e => {
        const v = parseFloat(e.target.value);
        document.getElementById('in_wtLbs').value = v ? (v * LBS_FACTOR).toFixed(2) : '';
    });
    document.getElementById('in_wtLbs').addEventListener('input', e => {
        const v = parseFloat(e.target.value);
        document.getElementById('in_netWt').value = v ? (v / LBS_FACTOR).toFixed(2) : '';
    });
}

