<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Yarn Manager - Inward & Outward</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js"></script>
    <!-- Supabase JS -->
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        :root {
            --primary: #1e293b;
            --secondary: #475569;
            --accent: #4f46e5;
            --listA: #059669;
            --listB: #7c3aed;
            --danger: #e11d48;
            --warning: #f59e0b;
            --bg: #f8fafc;
        }

        * { box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', 'Roboto', Helvetica, Arial, sans-serif;
            background-color: var(--bg);
            margin: 0;
            padding: 12px;
            color: #1e293b;
        }

        .container {
            max-width: 100%;
            margin: 0 auto;
            background: white;
            padding: 16px;
            border-radius: 12px;
            box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
            padding-bottom: 80px;
        }

        h1 {
            color: var(--primary);
            margin-top: 0;
            border-bottom: 3px solid var(--accent);
            display: inline-block;
            padding-bottom: 5px;
            font-size: 1.4rem;
        }

        /* ===== LOADING OVERLAY ===== */
        #loadingOverlay {
            position: fixed; inset: 0; background: rgba(255,255,255,0.85);
            z-index: 9999; display: flex; flex-direction: column;
            align-items: center; justify-content: center; gap: 12px;
            font-size: 1rem; font-weight: 600; color: var(--primary);
        }
        .spinner {
            width: 40px; height: 40px;
            border: 4px solid #e2e8f0;
            border-top-color: var(--accent);
            border-radius: 50%;
            animation: spin 0.7s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
        #loadingOverlay.hidden { display: none; }

        /* ===== TABS ===== */
        .tab-container {
            display: flex;
            gap: 8px;
            margin-bottom: 20px;
            position: sticky;
            top: 0;
            z-index: 50;
            background: white;
            padding: 8px 0 0;
        }
        .tab-button {
            flex: 1;
            padding: 12px 10px;
            border: none;
            background: #f1f5f9;
            color: var(--secondary);
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            border-radius: 8px 8px 0 0;
            transition: all 0.2s;
            min-height: 48px;
        }
        .tab-button.active {
            background: white;
            color: var(--primary);
            border-bottom: 4px solid var(--accent);
        }
        .tab-content { display: none; }
        .tab-content.active { display: block; }

        /* ===== FORM ===== */
        .input-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
            gap: 12px;
            background-color: #fff;
            padding: 16px;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            margin-bottom: 16px;
        }
        .input-grid.editing { border: 2px solid var(--warning); background-color: #fffbeb; }
        .form-group { display: flex; flex-direction: column; }
        .form-group label {
            font-size: 11px; font-weight: 700; color: var(--secondary);
            margin-bottom: 5px; text-transform: uppercase;
        }
        .form-group input, .form-group select {
            padding: 11px 10px; border: 1px solid #cbd5e1; border-radius: 6px;
            font-size: 15px; width: 100%;
            transition: border-color 0.2s;
            -webkit-appearance: none;
            min-height: 44px;
        }
        .form-group input:focus, .form-group select:focus { border-color: var(--accent); outline: none; }
        .auto-calc { background-color: #f1f5f9; font-weight: bold; }

        /* ===== ACTIONS ===== */
        .main-actions {
            display: flex; gap: 10px; margin-bottom: 24px;
            padding-bottom: 16px; border-bottom: 1px solid #f1f5f9;
            flex-wrap: wrap;
        }
        button {
            padding: 12px 18px; border: none; border-radius: 6px;
            font-weight: 600; cursor: pointer; font-size: 14px;
            display: inline-flex; align-items: center; gap: 6px;
            color: white; transition: all 0.2s;
            min-height: 44px;
            -webkit-tap-highlight-color: transparent;
        }
        button:active { filter: brightness(0.9); transform: scale(0.97); }
        .btn-add { background-color: var(--accent); flex: 1; justify-content: center; }
        .btn-update { background-color: var(--warning); flex: 1; justify-content: center; display: none; color: #1e293b; }
        .btn-reset { background-color: #64748b; }

        /* ===== FILTER BAR ===== */
        .filter-bar {
            background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px;
            padding: 12px; margin-bottom: 0;
            display: flex; flex-wrap: wrap; gap: 10px; align-items: flex-end;
        }
        .filter-bar .fg { display: flex; flex-direction: column; gap: 4px; flex: 1; min-width: 120px; }
        .filter-bar label { font-size: 10px; font-weight: 700; color: var(--secondary); text-transform: uppercase; }
        .filter-bar input[type="text"], .filter-bar input[type="date"] {
            padding: 8px 10px; border: 1px solid #cbd5e1; border-radius: 6px;
            font-size: 13px; width: 100%; min-height: 38px;
        }
        .filter-bar input:focus { border-color: var(--accent); outline: none; }
        .filter-bar .fg-actions { display: flex; gap: 8px; align-items: flex-end; }
        .btn-filter-clear {
            background: #64748b; color: white; padding: 8px 14px; border-radius: 6px;
            font-size: 12px; font-weight: 600; border: none; cursor: pointer;
            min-height: 38px; white-space: nowrap;
        }
        .filter-count { font-size: 11px; color: var(--secondary); align-self: flex-end; white-space: nowrap; padding-bottom: 4px; }

        /* ===== LIST SECTIONS ===== */
        .list-section { margin-bottom: 36px; border: 1px solid #e2e8f0; border-radius: 8px; overflow: hidden; }
        .list-header {
            padding: 10px 12px; display: flex; justify-content: space-between;
            align-items: center; color: white; flex-wrap: wrap; gap: 8px;
        }
        .list-header-title { font-weight: 700; font-size: 0.95rem; }
        .header-A { background-color: #0f172a; }
        .header-B { background-color: var(--listB); }
        .list-header-actions { display: flex; gap: 6px; flex-wrap: wrap; }
        .list-header button { background-color: var(--listA); padding: 7px 12px; font-size: 12px; min-height: 36px; }
        .table-wrapper { overflow-x: auto; max-height: 420px; -webkit-overflow-scrolling: touch; }
        table { width: 100%; border-collapse: collapse; min-width: 900px; background: white; }
        thead th {
            background-color: #f8fafc; color: #475569; padding: 10px 8px; text-align: left;
            font-size: 11px; position: sticky; top: 0; z-index: 5; border-bottom: 2px solid #e2e8f0;
            cursor: pointer; user-select: none; white-space: nowrap;
        }
        thead th:hover { background: #f1f5f9; }
        thead th .sort-icon { margin-left: 4px; opacity: 0.4; }
        thead th.sort-asc .sort-icon::after { content: '▲'; }
        thead th.sort-desc .sort-icon::after { content: '▼'; }
        thead th:not(.sort-asc):not(.sort-desc) .sort-icon::after { content: '⇅'; }
        tbody td { padding: 9px 8px; border-bottom: 1px solid #f1f5f9; font-size: 13px; }
        tbody tr.selected-row { background: #eff6ff; }
        tfoot tr { background-color: #f8fafc; font-weight: bold; border-top: 2px solid #1e293b; }
        tfoot td { padding: 10px 8px; color: var(--primary); font-size: 13px; }

        /* ===== CHECKBOX COL ===== */
        .cb-col { width: 36px; text-align: center; }
        .cb-col input[type="checkbox"] { width: 18px; height: 18px; cursor: pointer; accent-color: var(--accent); }
        .bulk-bar {
            display: none; background: #fef2f2; border: 1px solid #fecaca;
            padding: 10px 14px; border-radius: 6px; margin: 8px 0;
            align-items: center; gap: 10px; flex-wrap: wrap;
        }
        .bulk-bar.visible { display: flex; }
        .bulk-bar span { font-size: 13px; font-weight: 600; color: var(--danger); flex: 1; }
        .btn-bulk-del { background: var(--danger); padding: 8px 14px; font-size: 13px; }
        .btn-bulk-cancel { background: #64748b; padding: 8px 14px; font-size: 13px; }

        /* ===== ICON BUTTONS ===== */
        .icon-btn { padding: 7px 10px; border-radius: 4px; border: none; cursor: pointer; margin-right: 3px; min-height: 32px; }
        .edit-btn { background: var(--warning); color: #1e293b; }
        .del-btn { background: var(--danger); color: white; }
        .copy-btn { background: #0ea5e9; color: white; }

        /* ===== UNDO TOAST ===== */
        #toast {
            visibility: hidden; min-width: 260px; background-color: #1e293b; color: #fff;
            text-align: center; border-radius: 8px; padding: 14px 18px; position: fixed;
            z-index: 200; left: 50%; bottom: 24px; transform: translateX(-50%);
            display: flex; align-items: center; gap: 12px; justify-content: center;
            box-shadow: 0 8px 24px rgba(0,0,0,0.3);
        }
        #toast.show { visibility: visible; animation: fadein 0.3s; }
        #toast.hiding { animation: fadeout 0.4s forwards; }
        #toast-undo-btn {
            background: var(--accent); color: white; border: none; border-radius: 5px;
            padding: 6px 14px; font-weight: 700; cursor: pointer; font-size: 13px;
            display: none; min-height: 32px;
        }
        #toast-undo-btn.visible { display: inline-flex; align-items: center; }
        @keyframes fadein { from { bottom: 0; opacity: 0; } to { bottom: 24px; opacity: 1; } }
        @keyframes fadeout { from { bottom: 24px; opacity: 1; } to { bottom: 0; opacity: 0; } }

        /* ===== MISC ===== */
        .freq-badge {
            background-color: var(--danger); color: white; padding: 2px 6px;
            border-radius: 10px; font-size: 11px; margin-left: 6px;
        }
        .sum-only { color: var(--listB); font-weight: bold; font-size: 13px; }

        /* ===== STOCK SUMMARY DASHBOARD ===== */
        .stock-dashboard {
            margin-top: 8px; padding: 14px 16px;
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            border-radius: 10px; color: white;
        }
        .stock-dashboard h3 { margin: 0 0 12px; font-size: 0.95rem; color: rgba(255,255,255,0.7); text-transform: uppercase; letter-spacing: 0.5px; }
        .dash-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 10px; }
        .dash-card { background: rgba(255,255,255,0.08); border-radius: 8px; padding: 12px 14px; text-align: center; }
        .dash-card .dc-label { font-size: 10px; color: rgba(255,255,255,0.55); text-transform: uppercase; margin-bottom: 6px; letter-spacing: 0.4px; }
        .dash-card .dc-value { font-size: 1.5rem; font-weight: 800; }
        .dc-in { color: #34d399; }
        .dc-out { color: #f87171; }
        .dc-rem { color: #818cf8; }
        .dc-sku { color: #fbbf24; }

        /* ===== BACKUP REMINDER ===== */
        .backup-bar {
            display: none; background: #fffbeb; border: 1px solid #fde68a; border-radius: 8px;
            padding: 10px 14px; margin-bottom: 16px;
            align-items: center; gap: 10px; flex-wrap: wrap;
        }
        .backup-bar.visible { display: flex; }
        .backup-bar span { font-size: 13px; flex: 1; color: #92400e; font-weight: 600; }
        .btn-backup { background: var(--warning); color: #1e293b; padding: 8px 14px; font-size: 13px; }
        .btn-backup-dismiss { background: #64748b; padding: 8px 12px; font-size: 12px; }

        /* ===== MOBILE RESPONSIVE ===== */
        @media (max-width: 600px) {
            body { padding: 8px; }
            .container { padding: 10px; padding-bottom: 80px; }
            h1 { font-size: 1.1rem; }
            .tab-button { font-size: 0.8rem; padding: 10px 6px; }
            .input-grid { grid-template-columns: 1fr 1fr; gap: 10px; padding: 12px; }
            .filter-bar { gap: 8px; }
            .filter-bar .fg { min-width: 100px; }
            .main-actions { gap: 8px; }
            .btn-reset { flex: 0 0 auto; padding: 12px 14px; }
            .list-header { padding: 8px 10px; }
            .list-header-actions button { padding: 6px 10px; font-size: 11px; }
            .dash-cards { grid-template-columns: 1fr 1fr; }
            .dash-card .dc-value { font-size: 1.2rem; }
        }
        @media (max-width: 380px) {
            .input-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

<!-- LOADING OVERLAY -->
<div id="loadingOverlay">
    <div class="spinner"></div>
    <span id="loadingText">Connecting to database…</span>
</div>

<div class="container">
    <h1>🧶 Yarn Management System</h1>

    <!-- BACKUP REMINDER -->
    <div class="backup-bar" id="backupBar">
        <span>⚠️ It's been 7+ days since your last backup. Export your data to keep it safe!</span>
        <button class="btn-backup" onclick="doBackupExport()">📥 Backup Now</button>
        <button class="btn-backup-dismiss" onclick="dismissBackup()">Dismiss</button>
    </div>

    <div class="tab-container">
        <button id="tab-inward" class="tab-button active" onclick="switchTab(0)">📥 INWARD</button>
        <button id="tab-outward" class="tab-button" onclick="switchTab(1)">📤 OUTWARD</button>
    </div>

    <!-- ==================== INWARD SECTION ==================== -->
    <div id="inward-section" class="tab-content active">
        <div class="input-grid" id="inwardForm">
            <div class="form-group"><label>Date</label><input type="date" id="in_date"></div>
            <div class="form-group"><label>Inward No</label><input type="text" id="in_inward" list="list_in_inward" autocomplete="off"></div>
            <div class="form-group"><label>Count</label><input type="text" id="in_count" list="list_in_count" autocomplete="off"></div>
            <div class="form-group"><label>Brand</label><input type="text" id="in_brand" list="list_in_brand" autocomplete="off"></div>
            <div class="form-group"><label>Lot No</label><input type="text" id="in_lotNo" list="list_in_lotNo" autocomplete="off"></div>
            <div class="form-group"><label>Paper Cone</label><input type="text" id="in_peparCon" list="list_in_peparCon" autocomplete="off"></div>
            <div class="form-group"><label>Cones/Bag</label><input type="text" id="in_conPrBag" list="list_in_conPrBag" autocomplete="off"></div>
            <div class="form-group"><label>Gross Wt</label><input type="text" id="in_grossWt"></div>
            <div class="form-group"><label>Net Wt (KG)</label><input type="number" inputmode="decimal" id="in_netWt" class="auto-calc"></div>
            <div class="form-group"><label>Wt (LBS)</label><input type="number" inputmode="decimal" id="in_wtLbs" class="auto-calc"></div>
            <div class="form-group"><label>Bags</label><input type="number" inputmode="numeric" id="in_netBag"></div>
            <div class="form-group"><label>Packs</label><input type="number" inputmode="numeric" id="in_netPack"></div>
            <div class="form-group"><label>Lab Status</label>
                <select id="in_labTesting">
                    <option value="Pending">Pending</option>
                    <option value="Pass">Pass</option>
                    <option value="Fail">Fail</option>
                </select>
            </div>
            <div class="form-group"><label>Vehicle</label><input type="text" id="in_vehicle" list="list_in_vehicle" autocomplete="off"></div>
            <div class="form-group"><label>Party</label><input type="text" id="in_party" list="list_in_party" autocomplete="off"></div>
        </div>

        <datalist id="list_in_inward"></datalist>
        <datalist id="list_in_count"></datalist>
        <datalist id="list_in_brand"></datalist>
        <datalist id="list_in_lotNo"></datalist>
        <datalist id="list_in_peparCon"></datalist>
        <datalist id="list_in_conPrBag"></datalist>
        <datalist id="list_in_vehicle"></datalist>
        <datalist id="list_in_party"></datalist>

        <div class="main-actions">
            <button id="in_btnAdd" class="btn-add" onclick="inwardHandleAdd()">＋ Add Entry</button>
            <button id="in_btnUpdate" class="btn-update" onclick="inwardHandleUpdate()">✔ Update Entry</button>
            <button class="btn-reset" onclick="inwardResetForm()">✕ Clear</button>
        </div>

        <!-- LIST A -->
        <div class="list-section">
            <div class="list-header header-A">
                <span class="list-header-title">LIST A — Master Log (Inward)</span>
                <div class="list-header-actions">
                    <button onclick="inwardExport('A','xlsx')">Excel</button>
                    <button onclick="inwardExport('A','pdf')">PDF</button>
                    <button onclick="document.getElementById('in_importFile').click()">Import</button>
                </div>
            </div>
            <div class="filter-bar" id="inA_filterBar">
                <div class="fg"><label>Count</label><input type="text" id="inA_countInput" placeholder="Filter count…" oninput="filterTable('inA')"></div>
                <div class="fg"><label>Brand</label><input type="text" id="inA_brandInput" placeholder="Filter brand…" oninput="filterTable('inA')"></div>
                <div class="fg"><label>From Date</label><input type="date" id="inA_dateFrom" oninput="filterTable('inA')"></div>
                <div class="fg"><label>To Date</label><input type="date" id="inA_dateTo" oninput="filterTable('inA')"></div>
                <div class="fg-actions">
                    <button class="btn-filter-clear" onclick="clearSearch('inA')">✕ Clear</button>
                    <span class="filter-count" id="inA_rowCount"></span>
                </div>
            </div>
            <div class="bulk-bar" id="inA_bulkBar">
                <span id="inA_bulkCount">0 selected</span>
                <button class="btn-bulk-del" onclick="bulkDelete('in')">🗑 Delete Selected</button>
                <button class="btn-bulk-cancel" onclick="cancelBulk('inA')">Cancel</button>
            </div>
            <div class="table-wrapper">
                <table id="in_tableA"><thead></thead><tbody></tbody><tfoot></tfoot></table>
            </div>
        </div>

        <!-- LIST B -->
        <div class="list-section">
            <div class="list-header header-B">
                <span class="list-header-title">LIST B — Unique Summary</span>
                <div class="list-header-actions">
                    <button onclick="inwardExport('B','xlsx')">Excel</button>
                    <button onclick="inwardExport('B','pdf')">PDF</button>
                </div>
            </div>
            <div class="filter-bar">
                <div class="fg"><label>Count</label><input type="text" id="inB_countInput" placeholder="Filter count…" oninput="filterTable('inB')"></div>
                <div class="fg"><label>Brand</label><input type="text" id="inB_brandInput" placeholder="Filter brand…" oninput="filterTable('inB')"></div>
                <div class="fg"><label>From Date</label><input type="date" id="inB_dateFrom" oninput="filterTable('inB')"></div>
                <div class="fg"><label>To Date</label><input type="date" id="inB_dateTo" oninput="filterTable('inB')"></div>
                <div class="fg-actions">
                    <button class="btn-filter-clear" onclick="clearSearch('inB')">✕ Clear</button>
                    <span class="filter-count" id="inB_rowCount"></span>
                </div>
            </div>
            <div class="table-wrapper">
                <table id="in_tableB"><thead></thead><tbody></tbody><tfoot></tfoot></table>
            </div>
        </div>

        <!-- INWARD STOCK DASHBOARD -->
        <div class="stock-dashboard" id="inward_dashboard">
            <h3>📊 Stock Summary</h3>
            <div class="dash-cards">
                <div class="dash-card"><div class="dc-label">Total Inward Bags</div><div class="dc-value dc-in" id="dash_in_bags">0</div></div>
                <div class="dash-card"><div class="dc-label">Total Inward Packs</div><div class="dc-value dc-in" id="dash_in_packs">0</div></div>
                <div class="dash-card"><div class="dc-label">Total Outward Bags</div><div class="dc-value dc-out" id="dash_out_bags">0</div></div>
                <div class="dash-card"><div class="dc-label">Total Outward Packs</div><div class="dc-value dc-out" id="dash_out_packs">0</div></div>
                <div class="dash-card"><div class="dc-label">Remaining Bags</div><div class="dc-value dc-rem" id="dash_rem_bags">0</div></div>
                <div class="dash-card"><div class="dc-label">Remaining Packs</div><div class="dc-value dc-rem" id="dash_rem_packs">0</div></div>
                <div class="dash-card"><div class="dc-label">Unique SKUs</div><div class="dc-value dc-sku" id="dash_skus">0</div></div>
                <div class="dash-card"><div class="dc-label">Total Entries</div><div class="dc-value dc-sku" id="dash_entries">0</div></div>
            </div>
        </div>

        <input type="file" id="in_importFile" hidden accept=".xlsx,.xls" onchange="inwardHandleImport(event)">
    </div>

    <!-- ==================== OUTWARD SECTION ==================== -->
    <div id="outward-section" class="tab-content">
        <div class="input-grid" id="outwardForm">
            <div class="form-group"><label>Date</label><input type="date" id="out_date"></div>
            <div class="form-group"><label>D.O #</label><input type="text" id="out_doNo" list="list_out_doNo" autocomplete="off"></div>
            <div class="form-group"><label>Count</label><input type="text" id="out_count" list="list_out_count" autocomplete="off"></div>
            <div class="form-group"><label>Brand</label><input type="text" id="out_brand" list="list_out_brand" autocomplete="off"></div>
            <div class="form-group"><label>Against Count</label><input type="text" id="out_againstCount" list="list_out_againstCount" autocomplete="off"></div>
            <div class="form-group"><label>Against Brand</label><input type="text" id="out_againstBrand" list="list_out_againstBrand" autocomplete="off"></div>
            <div class="form-group"><label>Lot No</label><input type="text" id="out_lotNo" list="list_out_lotNo" autocomplete="off"></div>
            <div class="form-group"><label>Paper Cone</label><input type="text" id="out_peparCon" list="list_out_peparCon" autocomplete="off"></div>
            <div class="form-group"><label>Cones/Bag</label><input type="text" id="out_conPrBag" list="list_out_conPrBag" autocomplete="off"></div>
            <div class="form-group"><label>Gross Wt Pr Bag</label><input type="text" id="out_grossWtPrBag"></div>
            <div class="form-group"><label>Net Wt Pr Bag (KG)</label><input type="number" inputmode="decimal" id="out_netWtPrBag" class="auto-calc"></div>
            <div class="form-group"><label>Wt Pr Bag (LBS)</label><input type="number" inputmode="decimal" id="out_wtLbsPrBag" class="auto-calc"></div>
            <div class="form-group"><label>Net Bag</label><input type="number" inputmode="numeric" id="out_netBag"></div>
            <div class="form-group"><label>Net Pack</label><input type="number" inputmode="numeric" id="out_netPack"></div>
