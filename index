<script>
// ==================== SUPABASE CONFIG ====================
const SUPABASE_URL = 'https://nagjcwuvrybwcsgyihbx.supabase.co';
const SUPABASE_KEY = 'sb_publishable_AW8UMNO4gDcvd4bI5Q7wIA_N_MBrJks';
const { createClient } = supabase;
const db = createClient(SUPABASE_URL, SUPABASE_KEY);

// ==================== IN-MEMORY CACHE ====================
// All data is fetched once from Supabase at startup, stored here,
// and synced back on every add / update / delete.
let inwardCache = [];  // rows from inward table
let outwardCache = []; // rows from outward table

// ==================== CONSTANTS ====================
const LBS_FACTOR = 2.20462;
let undoStack = { type: null, data: null };
let toastTimer = null;
const sortState = { inA: { col: -1, dir: 1 }, outA: { col: -1, dir: 1 } };

const in_keys = ["date","inward","count","brand","lotNo","peparCon","conPrBag","grossWt","netWt","wtLbs","netBag","netPack","labTesting","vehicle","party"];
const in_headersA = ["DATE","INWARD","COUNT","BRAND","LOT NO","P.CONE","C/BAG","GROSS","NET KG","WT LBS","BAGS","PACKS","LAB","VEHICLE","PARTY"];
const in_headersB = ["SR NO","COUNT","BRAND","LOT NO","P.CONE","C/BAG","BAGS IN","PACKS IN","BAGS OUT","PACKS OUT","BAGS REM","PACKS REM","PARTY"];
let in_currentEditIndex = -1;
let in_currentEditId = null; // Supabase row id for inward

const out_keys = ["date","doNo","count","brand","againstCount","againstBrand","lotNo","peparCon","conPrBag","grossWtPrBag","netWtPrBag","wtLbsPrBag","netBag","netPack","vehicle","party"];
const out_headersA = ["DATE","D.O #","COUNT","BRAND","AGAINST COUNT","AGAINST BRAND","LOT NO","P.CONE","C/BAG","GROSS PR BAG","NET PR BAG KG","WT PR BAG LBS","BAGS","PACKS","VEHICLE","PARTY"];
let out_currentEditIndex = -1;
let out_currentEditId = null; // Supabase row id for outward

// ==================== LOADING ====================
function showLoading(msg = 'Please wait…') {
    document.getElementById('loadingText').textContent = msg;
    document.getElementById('loadingOverlay').classList.remove('hidden');
}
function hideLoading() {
    document.getElementById('loadingOverlay').classList.add('hidden');
}

// ==================== SUPABASE DATA ACCESS ====================
async function fetchAll() {
    showLoading('Loading data from Supabase…');
    const [inRes, outRes] = await Promise.all([
        db.from('inward').select('*').order('id', { ascending: true }),
        db.from('outward').select('*').order('id', { ascending: true })
    ]);
    if (inRes.error) { alert('Error loading inward: ' + inRes.error.message); }
    else inwardCache = inRes.data || [];

    if (outRes.error) { alert('Error loading outward: ' + outRes.error.message); }
    else outwardCache = outRes.data || [];

    hideLoading();
    refreshAll();
}

function refreshAll() {
    inwardRefreshTables();
    inwardUpdateAutocompletes();
    outwardRefreshTables();
    outwardUpdateAutocompletes();
    updateDashboards();
    checkBackupReminder();
    reapplySearches();
}

// ==================== INWARD CRUD ====================
async function inwardHandleAdd() {
    const entry = buildEntry('in_', in_keys);
    if (!entry.date || !entry.inward) return alert("Date and Inward No are required!");
    showLoading('Saving…');
    const { data, error } = await db.from('inward').insert([entry]).select();
    hideLoading();
    if (error) return alert('Error saving: ' + error.message);
    inwardCache.push(data[0]);
    inwardResetForm();
    refreshAll();
    showToast("Inward Entry Added!");
}

async function inwardHandleUpdate() {
    const entry = buildEntry('in_', in_keys);
    showLoading('Updating…');
    const { error } = await db.from('inward').update(entry).eq('id', in_currentEditId);
    hideLoading();
    if (error) return alert('Error updating: ' + error.message);
    inwardCache[in_currentEditIndex] = { ...inwardCache[in_currentEditIndex], ...entry };
    inwardResetForm();
    refreshAll();
    showToast("Inward Entry Updated!");
}

async function inwardDeleteRow(index) {
    const item = inwardCache[index];
    if (!confirm('Delete this entry?')) return;
    showLoading('Deleting…');
    const { error } = await db.from('inward').delete().eq('id', item.id);
    hideLoading();
    if (error) return alert('Error deleting: ' + error.message);
    undoStack = { type: 'in', data: item, index };
    inwardCache.splice(index, 1);
    refreshAll();
    showToast("Entry Deleted", true);
}

async function undoDelete() {
    if (!undoStack.data) return;
    const { type, data } = undoStack;
    showLoading('Restoring…');
    const table = type === 'in' ? 'inward' : 'outward';
    const { id, ...rest } = data; // remove id to let Supabase assign
    const { data: restored, error } = await db.from(table).insert([rest]).select();
    hideLoading();
    if (error) return alert('Error restoring: ' + error.message);
    if (type === 'in') inwardCache.push(restored[0]);
    else outwardCache.push(restored[0]);
    undoStack = { type: null, data: null };
    hideToast();
    refreshAll();
    showToast("Entry Restored ✓");
}

async function inwardBulkDelete(ids, indices) {
    showLoading('Deleting…');
    const { error } = await db.from('inward').delete().in('id', ids);
    hideLoading();
    if (error) return alert('Error: ' + error.message);
    inwardCache = inwardCache.filter((_, i) => !indices.includes(i));
    cancelBulk('inA');
    refreshAll();
    showToast(`${ids.length} records deleted`);
}

async function outwardBulkDelete(ids, indices) {
    showLoading('Deleting…');
    const { error } = await db.from('outward').delete().in('id', ids);
    hideLoading();
    if (error) return alert('Error: ' + error.message);
    outwardCache = outwardCache.filter((_, i) => !indices.includes(i));
    cancelBulk('outA');
    refreshAll();
    showToast(`${ids.length} records deleted`);
}

